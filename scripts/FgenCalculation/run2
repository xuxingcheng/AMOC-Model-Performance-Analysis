set -eo pipefail

# Run from the directory where you submitted the job
cd "$PBS_O_WORKDIR"

echo "=== JOB INFO ==="
echo "HOST: $(hostname)"
echo "NODES:"
uniq "$PBS_NODEFILE"
echo "Total slots (nodefile lines): $(wc -l < "$PBS_NODEFILE")"
echo "WORKDIR: $PBS_O_WORKDIR"
date

# NCAR: load conda module inside batch jobs before activating env
module load conda/latest
conda activate amoc-env

# Avoid oversubscription by threaded libs
export OMP_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export MKL_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

python /glade/u/home/stevenxu/AMOCproject/scripts/FgenCalculation/Fgenrun2.py